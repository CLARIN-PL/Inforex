{
  "run-mode": "report",
  "report-theme": "light",
  "stopwords": "/opt/korpuskop/dics/stopwords_pl.txt",
  "reference-vocab": "/opt/korpuskop/dics/sgjp.tab",
  "llm-provider": "clarin",
  "llm-model": "or-gpt-oss-20b",
  "nmf-topics": 10,
  "nmf-iters": 90,
  "nmf-top-words": 25,
  "nmf-max-vocab": 5000,
  "nmf-min-df": 5,
  "nmf-cleaning-profile": "aggressive",
  "nmf-enable-bigrams": true,
  "nmf-min-bigram-count": 8,
  "nmf-seeds": 3,
  "nmf-eval-every": 5,
  "nmf-early-stop-tol": 0.0005,
  "nmf-early-stop-patience": 10,
  "nmf-backend": "gemm",
  "threads": 8,
  "sense-emotions": "/opt/korpuskop/dics/sense_emotions.tab",
  "limit-corpus-size": 5000
}
